---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<!-- ══════════════════════════════════════════════
	     HERO
	     ══════════════════════════════════════════════ -->
	<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
		<!-- Background image -->
		<div class="absolute inset-0 z-0">
			<img
				src="https://images.unsplash.com/photo-1487412947147-5cebf100ffc2?w=1920&q=80&auto=format&fit=crop"
				alt=""
				class="w-full h-full object-cover object-top"
				loading="eager"
			/>
			<div class="absolute inset-0 bg-gradient-to-b from-dark/80 via-dark/70 to-dark"></div>
			<div class="absolute inset-0 bg-gradient-to-r from-dark/90 via-dark/40 to-dark/80"></div>
		</div>

		<!-- Brushstroke decoration -->
		<svg class="brushstroke-bg hero-brush absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[300px]" viewBox="0 0 800 300" fill="none" xmlns="http://www.w3.org/2000/svg">
			<path d="M50 150 Q200 50 400 150 Q600 250 750 150" stroke="#e91e7a" stroke-width="80" stroke-linecap="round" opacity="0.6" />
		</svg>

		<!-- Diagonal gold line decoration -->
		<div class="absolute top-0 right-0 w-px h-[60vh] bg-gradient-to-b from-transparent via-gold/30 to-transparent rotate-12 translate-x-[-20vw]"></div>

		<!-- Content -->
		<div class="relative z-10 text-center px-6 max-w-5xl mx-auto">
			<!-- Rating badge -->
			<div class="hero-badge inline-flex items-center gap-2 mb-8 px-5 py-2.5 border border-gold/40 bg-dark/60 backdrop-blur-sm rounded-full">
				<div class="flex text-gold text-sm tracking-wider">
					<span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span>
				</div>
				<span class="text-cream/80 text-sm font-body font-light">4.9 &middot; 84 rese&ntilde;as</span>
			</div>

			<!-- Main title -->
			<h1 class="relative">
				<span class="hero-title-1 block font-display text-[clamp(3.5rem,12vw,10rem)] leading-[0.85] tracking-[0.08em] text-white">
					ESMERALDA
				</span>
				<span class="hero-title-2 block font-display text-[clamp(3.5rem,12vw,10rem)] leading-[0.85] tracking-[0.08em] text-white">
					ROBLES
				</span>
			</h1>

			<!-- Decorative line -->
			<div class="hero-line flex items-center justify-center gap-4 my-6">
				<span class="block w-16 h-px bg-gradient-to-r from-transparent to-gold"></span>
				<span class="font-serif italic text-gold text-lg md:text-xl tracking-[0.2em]">MAKEUP ACADEMY</span>
				<span class="block w-16 h-px bg-gradient-to-l from-transparent to-gold"></span>
			</div>

			<!-- Subtitle -->
			<p class="hero-subtitle font-serif italic text-cream/70 text-lg md:text-xl max-w-xl mx-auto">
				Transforma tu pasi&oacute;n en tu profesi&oacute;n &middot; Guadalajara
			</p>

			<!-- CTA -->
			<div class="hero-cta mt-10">
				<a href="#cursos"
					class="group relative inline-flex items-center gap-3 px-8 py-4 bg-pink text-white font-body font-medium text-sm tracking-[0.15em] uppercase overflow-hidden transition-all duration-500 hover:bg-pink-light hover:shadow-[0_0_40px_rgba(233,30,122,0.4)]">
					<span class="relative z-10">Conoce nuestros cursos</span>
					<svg class="relative z-10 w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
					</svg>
					<div class="absolute inset-0 bg-gradient-to-r from-pink-light to-pink scale-x-0 origin-left transition-transform duration-500 group-hover:scale-x-100"></div>
				</a>
			</div>
		</div>

		<!-- Scroll indicator -->
		<div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-50">
			<span class="text-[10px] tracking-[0.3em] uppercase font-body text-cream/60">Scroll</span>
			<div class="w-px h-8 bg-gradient-to-b from-cream/40 to-transparent animate-pulse"></div>
		</div>
	</section>

	<!-- ══════════════════════════════════════════════
	     CURSOS
	     ══════════════════════════════════════════════ -->
	<section id="cursos" class="relative py-28 md:py-36 px-6 bg-dark">
		<!-- Section brushstroke bg -->
		<svg class="brushstroke-bg absolute -top-20 -right-40 w-[600px] h-[400px] rotate-12" viewBox="0 0 600 400" fill="none">
			<path d="M50 200 Q150 50 300 200 Q450 350 550 200" stroke="#c9a84c" stroke-width="60" stroke-linecap="round" opacity="0.5" />
		</svg>

		<div class="max-w-6xl mx-auto">
			<!-- Section header -->
			<div data-animate="fade-up" class="mb-20">
				<span class="font-serif italic text-gold text-lg tracking-wider">Programas</span>
				<h2 class="font-display text-[clamp(2.5rem,6vw,5rem)] leading-[0.9] tracking-[0.05em] text-white mt-2">
					NUESTROS<br/>CURSOS
				</h2>
				<div class="w-20 h-0.5 bg-pink mt-6"></div>
			</div>

			<!-- Course grid — asymmetric -->
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">

				<!-- Course 1 -->
				<div data-animate="fade-up" data-delay="1" class="course-card relative bg-dark-card border border-white/5 p-0 overflow-hidden group">
					<div class="relative h-56 overflow-hidden">
						<img src="https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?w=700&q=80&auto=format&fit=crop"
							alt="Alumna practicando maquillaje b&aacute;sico" class="course-img w-full h-full object-cover" loading="lazy" />
						<div class="absolute inset-0 bg-gradient-to-t from-dark-card via-transparent to-transparent"></div>
						<span class="course-number absolute top-4 right-6 font-display text-7xl text-white/10 -webkit-text-stroke-1 -webkit-text-stroke-white/20" style="-webkit-text-stroke: 1px rgba(255,255,255,0.15); color: transparent;">01</span>
					</div>
					<div class="p-8 pt-4">
						<h3 class="font-display text-2xl tracking-[0.08em] text-white mb-3">CURSO B&Aacute;SICO DE MAQUILLAJE</h3>
						<p class="font-body text-cream/50 text-sm leading-relaxed">
							Domina las bases del maquillaje profesional desde cero. Aprende preparaci&oacute;n de piel,
							correcciones, t&eacute;cnicas de aplicaci&oacute;n y los fundamentos que todo maquillista
							necesita para construir una carrera s&oacute;lida.
						</p>
					</div>
				</div>

				<!-- Course 2 — offset up -->
				<div data-animate="fade-up" data-delay="2" class="course-card relative bg-dark-card border border-white/5 p-0 overflow-hidden md:mt-16 group">
					<div class="relative h-56 overflow-hidden">
						<img src="https://images.unsplash.com/photo-1457972729786-0411a3b2b626?w=700&q=80&auto=format&fit=crop"
							alt="Maquillaje de novia elegante" class="course-img w-full h-full object-cover" loading="lazy" />
						<div class="absolute inset-0 bg-gradient-to-t from-dark-card via-transparent to-transparent"></div>
						<span class="course-number absolute top-4 right-6 font-display text-7xl" style="-webkit-text-stroke: 1px rgba(255,255,255,0.15); color: transparent;">02</span>
					</div>
					<div class="p-8 pt-4">
						<h3 class="font-display text-2xl tracking-[0.08em] text-white mb-3">MAQUILLAJE DE NOVIAS</h3>
						<p class="font-body text-cream/50 text-sm leading-relaxed">
							Especialízate en el servicio más demandado del mercado. Domina looks de larga duración,
							técnicas para fotografía y video, y aprende a gestionar el día más importante de tus clientas.
						</p>
					</div>
				</div>

				<!-- Course 3 -->
				<div data-animate="fade-up" data-delay="3" class="course-card relative bg-dark-card border border-white/5 p-0 overflow-hidden group">
					<div class="relative h-56 overflow-hidden">
						<img src="https://images.unsplash.com/photo-1516975080664-ed2fc6a32937?w=700&q=80&auto=format&fit=crop"
							alt="Maquillaje art&iacute;stico editorial" class="course-img w-full h-full object-cover" loading="lazy" />
						<div class="absolute inset-0 bg-gradient-to-t from-dark-card via-transparent to-transparent"></div>
						<span class="course-number absolute top-4 right-6 font-display text-7xl" style="-webkit-text-stroke: 1px rgba(255,255,255,0.15); color: transparent;">03</span>
					</div>
					<div class="p-8 pt-4">
						<h3 class="font-display text-2xl tracking-[0.08em] text-white mb-3">MAQUILLAJE ART&Iacute;STICO Y EDITORIAL</h3>
						<p class="font-body text-cream/50 text-sm leading-relaxed">
							Para quienes sue&ntilde;an con trabajar en moda, cine y televisi&oacute;n.
							Explora t&eacute;cnicas de fantas&iacute;a, efectos especiales y los looks
							creativos que definen las editoriales de las grandes revistas.
						</p>
					</div>
				</div>

				<!-- Course 4 — offset up -->
				<div data-animate="fade-up" data-delay="4" class="course-card relative bg-dark-card border border-white/5 p-0 overflow-hidden md:mt-16 group">
					<div class="relative h-56 overflow-hidden">
						<img src="https://images.unsplash.com/photo-1596462502278-27bfdc403348?w=700&q=80&auto=format&fit=crop"
							alt="Herramientas profesionales de maquillaje" class="course-img w-full h-full object-cover" loading="lazy" />
						<div class="absolute inset-0 bg-gradient-to-t from-dark-card via-transparent to-transparent"></div>
						<span class="course-number absolute top-4 right-6 font-display text-7xl" style="-webkit-text-stroke: 1px rgba(255,255,255,0.15); color: transparent;">04</span>
					</div>
					<div class="p-8 pt-4">
						<h3 class="font-display text-2xl tracking-[0.08em] text-white mb-3">MASTERCLASS ESPECIALIZADA</h3>
						<p class="font-body text-cream/50 text-sm leading-relaxed">
							Lleva tu t&eacute;cnica al siguiente nivel con workshops intensivos enfocados
							en tendencias actuales, nuevos productos y m&eacute;todos avanzados que
							te diferenciar&aacute;n en el mercado.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ══════════════════════════════════════════════
	     POR QU&Eacute; ESTUDIAR AQU&Iacute;
	     ══════════════════════════════════════════════ -->
	<section class="relative py-28 md:py-36 px-6 bg-dark-lighter overflow-hidden">
		<!-- Decorative diagonal lines -->
		<div class="absolute top-0 left-0 w-full h-full pointer-events-none">
			<div class="absolute top-20 -left-20 w-[1px] h-[50vh] bg-gradient-to-b from-transparent via-pink/20 to-transparent rotate-[20deg]"></div>
			<div class="absolute bottom-20 -right-20 w-[1px] h-[50vh] bg-gradient-to-b from-transparent via-gold/20 to-transparent -rotate-[15deg]"></div>
		</div>

		<div class="max-w-6xl mx-auto">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
				<!-- Left: editorial photo -->
				<div data-animate="fade-left" class="relative">
					<div class="relative">
						<img src="https://images.unsplash.com/photo-1560577091-04faf9c3f0c0?w=700&q=80&auto=format&fit=crop"
							alt="Maquillista profesional trabajando" class="w-full aspect-[3/4] object-cover" loading="lazy" />
						<!-- Overlapping accent frame -->
						<div class="absolute -bottom-4 -right-4 w-full h-full border border-gold/30 -z-10"></div>
						<!-- Pink accent block -->
						<div class="absolute -top-6 -left-6 w-24 h-24 bg-pink/20 backdrop-blur-sm"></div>
					</div>
				</div>

				<!-- Right: reasons -->
				<div>
					<div data-animate="fade-right" class="mb-12">
						<span class="font-serif italic text-gold text-lg tracking-wider">La diferencia</span>
						<h2 class="font-display text-[clamp(2rem,5vw,4rem)] leading-[0.9] tracking-[0.05em] text-white mt-2">
							&iquest;POR QU&Eacute;<br/>ESTUDIAR AQU&Iacute;?
						</h2>
						<div class="w-20 h-0.5 bg-pink mt-6"></div>
					</div>

					<div class="space-y-8">
						<!-- Reason 1 -->
						<div data-animate="fade-up" data-delay="1" class="flex gap-5 group">
							<div class="flex-shrink-0 w-12 h-12 flex items-center justify-center border border-gold/40 text-gold font-display text-xl transition-colors group-hover:bg-gold group-hover:text-dark">
								01
							</div>
							<div>
								<h3 class="font-display text-lg tracking-[0.08em] text-white mb-1">INSTRUCTORA CON TRAYECTORIA RECONOCIDA</h3>
								<p class="font-body text-cream/50 text-sm leading-relaxed">
									Aprende directamente de Esmeralda Robles, con a&ntilde;os de experiencia formando maquillistas profesionales en Guadalajara.
								</p>
							</div>
						</div>

						<!-- Reason 2 -->
						<div data-animate="fade-up" data-delay="2" class="flex gap-5 group">
							<div class="flex-shrink-0 w-12 h-12 flex items-center justify-center border border-gold/40 text-gold font-display text-xl transition-colors group-hover:bg-gold group-hover:text-dark">
								02
							</div>
							<div>
								<h3 class="font-display text-lg tracking-[0.08em] text-white mb-1">PR&Aacute;CTICA DESDE EL D&Iacute;A UNO</h3>
								<p class="font-body text-cream/50 text-sm leading-relaxed">
									Nada de solo teor&iacute;a. Desde tu primera clase est&aacute;s con brochas en mano, practicando en modelos reales.
								</p>
							</div>
						</div>

						<!-- Reason 3 -->
						<div data-animate="fade-up" data-delay="3" class="flex gap-5 group">
							<div class="flex-shrink-0 w-12 h-12 flex items-center justify-center border border-gold/40 text-gold font-display text-xl transition-colors group-hover:bg-gold group-hover:text-dark">
								03
							</div>
							<div>
								<h3 class="font-display text-lg tracking-[0.08em] text-white mb-1">GRUPOS REDUCIDOS</h3>
								<p class="font-body text-cream/50 text-sm leading-relaxed">
									Atenci&oacute;n personalizada en cada sesi&oacute;n. Grupos peque&ntilde;os para que cada alumna reciba la gu&iacute;a que necesita.
								</p>
							</div>
						</div>

						<!-- Reason 4 -->
						<div data-animate="fade-up" data-delay="4" class="flex gap-5 group">
							<div class="flex-shrink-0 w-12 h-12 flex items-center justify-center border border-gold/40 text-gold font-display text-xl transition-colors group-hover:bg-gold group-hover:text-dark">
								04
							</div>
							<div>
								<h3 class="font-display text-lg tracking-[0.08em] text-white mb-1">CERTIFICADO AL TERMINAR</h3>
								<p class="font-body text-cream/50 text-sm leading-relaxed">
									Recibe tu certificado de la academia al completar cada curso. Respaldo profesional para tu carrera como maquillista.
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ══════════════════════════════════════════════
	     GALER&Iacute;A
	     ══════════════════════════════════════════════ -->
	<section class="relative py-28 md:py-36 px-6 bg-dark">
		<div class="max-w-7xl mx-auto">
			<div data-animate="fade-up" class="text-center mb-16">
				<span class="font-serif italic text-gold text-lg tracking-wider">Portfolio</span>
				<h2 class="font-display text-[clamp(2rem,5vw,4rem)] leading-[0.9] tracking-[0.05em] text-white mt-2">GALER&Iacute;A</h2>
				<div class="w-20 h-0.5 bg-pink mt-6 mx-auto"></div>
			</div>

			<!-- Asymmetric masonry grid -->
			<div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 auto-rows-[180px] md:auto-rows-[220px]">
				<div data-animate="scale-in" data-delay="1" class="gallery-item rounded-sm row-span-2 col-span-1">
					<img src="https://images.unsplash.com/photo-1512496015851-a90fb38ba796?w=600&q=80&auto=format&fit=crop"
						alt="Close-up de maquillaje profesional de labios" class="w-full h-full object-cover" loading="lazy" />
				</div>
				<div data-animate="scale-in" data-delay="2" class="gallery-item rounded-sm col-span-1 md:col-span-2 row-span-1">
					<img src="https://images.unsplash.com/photo-1583241800698-e8ab01830a07?w=800&q=80&auto=format&fit=crop"
						alt="Paleta de sombras profesional" class="w-full h-full object-cover" loading="lazy" />
				</div>
				<div data-animate="scale-in" data-delay="3" class="gallery-item rounded-sm row-span-2">
					<img src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=600&q=80&auto=format&fit=crop"
						alt="Sesi&oacute;n de clase de maquillaje" class="w-full h-full object-cover" loading="lazy" />
				</div>
				<div data-animate="scale-in" data-delay="4" class="gallery-item rounded-sm col-span-1 md:col-span-2 row-span-1">
					<img src="https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?w=800&q=80&auto=format&fit=crop"
						alt="Aplicaci&oacute;n de maquillaje en modelo" class="w-full h-full object-cover" loading="lazy" />
				</div>
				<div data-animate="scale-in" data-delay="5" class="gallery-item rounded-sm col-span-1 row-span-1">
					<img src="https://images.unsplash.com/photo-1596462502278-27bfdc403348?w=600&q=80&auto=format&fit=crop"
						alt="Brochas de maquillaje profesional" class="w-full h-full object-cover" loading="lazy" />
				</div>
				<div data-animate="scale-in" data-delay="6" class="gallery-item rounded-sm col-span-1 row-span-1">
					<img src="https://images.unsplash.com/photo-1487412947147-5cebf100ffc2?w=600&q=80&auto=format&fit=crop"
						alt="Rostro con maquillaje editorial" class="w-full h-full object-cover" loading="lazy" />
				</div>
			</div>
		</div>
	</section>

	<!-- ══════════════════════════════════════════════
	     TESTIMONIOS
	     ══════════════════════════════════════════════ -->
	<section class="relative py-28 md:py-36 px-6 bg-dark-lighter overflow-hidden">
		<!-- Decorative quote mark -->
		<div class="absolute top-16 left-8 md:left-16 font-serif text-[12rem] md:text-[20rem] leading-none text-pink/5 select-none pointer-events-none">&ldquo;</div>

		<div class="max-w-6xl mx-auto relative z-10">
			<div data-animate="fade-up" class="text-center mb-16">
				<span class="font-serif italic text-gold text-lg tracking-wider">Alumnas</span>
				<h2 class="font-display text-[clamp(2rem,5vw,4rem)] leading-[0.9] tracking-[0.05em] text-white mt-2">TESTIMONIOS</h2>
				<div class="w-20 h-0.5 bg-pink mt-6 mx-auto"></div>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<!-- Testimonial 1 -->
				<div data-animate="fade-up" data-delay="1" class="testimonial-card bg-dark-card border border-white/5 p-8 relative">
					<div class="absolute top-0 left-0 w-full h-0.5 bg-gradient-to-r from-pink via-pink/50 to-transparent"></div>
					<div class="flex text-gold text-xs mb-4 tracking-wider">
						&#9733;&#9733;&#9733;&#9733;&#9733;
					</div>
					<p class="font-serif italic text-cream/70 text-lg leading-relaxed mb-6">
						&ldquo;Entr&eacute; sin saber nada y ahora trabajo como maquillista freelance. Esmeralda te ense&ntilde;a de verdad.&rdquo;
					</p>
					<div class="flex items-center gap-3">
						<div class="w-8 h-px bg-gold/40"></div>
						<span class="font-body text-sm text-cream/50 tracking-wider uppercase">Karla V.</span>
					</div>
				</div>

				<!-- Testimonial 2 — offset -->
				<div data-animate="fade-up" data-delay="2" class="testimonial-card bg-dark-card border border-white/5 p-8 relative md:mt-12">
					<div class="absolute top-0 left-0 w-full h-0.5 bg-gradient-to-r from-gold via-gold/50 to-transparent"></div>
					<div class="flex text-gold text-xs mb-4 tracking-wider">
						&#9733;&#9733;&#9733;&#9733;&#9733;
					</div>
					<p class="font-serif italic text-cream/70 text-lg leading-relaxed mb-6">
						&ldquo;La mejor inversi&oacute;n que he hecho. El curso de novias cambi&oacute; mi carrera.&rdquo;
					</p>
					<div class="flex items-center gap-3">
						<div class="w-8 h-px bg-gold/40"></div>
						<span class="font-body text-sm text-cream/50 tracking-wider uppercase">Daniela M.</span>
					</div>
				</div>

				<!-- Testimonial 3 -->
				<div data-animate="fade-up" data-delay="3" class="testimonial-card bg-dark-card border border-white/5 p-8 relative">
					<div class="absolute top-0 left-0 w-full h-0.5 bg-gradient-to-r from-pink via-gold/50 to-transparent"></div>
					<div class="flex text-gold text-xs mb-4 tracking-wider">
						&#9733;&#9733;&#9733;&#9733;&#9733;
					</div>
					<p class="font-serif italic text-cream/70 text-lg leading-relaxed mb-6">
						&ldquo;Grupos peque&ntilde;os, atenci&oacute;n personal y mucha pr&aacute;ctica. S&uacute;per recomendado.&rdquo;
					</p>
					<div class="flex items-center gap-3">
						<div class="w-8 h-px bg-gold/40"></div>
						<span class="font-body text-sm text-cream/50 tracking-wider uppercase">Andrea L.</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ══════════════════════════════════════════════
	     UBICACI&Oacute;N
	     ══════════════════════════════════════════════ -->
	<section class="relative py-28 md:py-36 px-6 bg-dark">
		<div class="max-w-6xl mx-auto">
